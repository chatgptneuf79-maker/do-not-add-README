{
  "name": "slp-sprint1-vertical-slice",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "build:open": "npm run build && open dist",
    "build:zip": "npm run build && node scripts/zip-dist.mjs",
    "open:artifacts": "open build_artifacts",
    "make:packet": "node scripts/make-packet.mjs",
    "make:release": "npm run build:zip && npm run make:packet && open build_artifacts",
    "postbuild": "cp public/_redirects dist/_redirects"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
